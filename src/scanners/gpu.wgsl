fn nb(k: i32, ok: ptr<function, array<u32, 8>>) -> i32 { var c=0; let ds = array<i32,8>(6,4,7,5,1,2,3,0); for(var d=0; d<8; d++) { let dr=ds[d]; var n=-1; if dr==0 {n=k+192; if n<=0||n>=36864 {n=-1;}} else if dr==1 {n=k-192; if n<=0||n>=36864 {n=-1;}} else if dr==2 {n=k-1; if n<0||n>=36864||k/192!=n/192 {n=-1;}} else if dr==3 {n=k+1; if n<0||n>=36864||k/192!=n/192 {n=-1;}} else if dr==4 {let t=k-1; if t>=0&&t<36864&&k/192==t/192 {n=t-192; if n<=0||n>=36864 {n=-1;}}} else if dr==5 {let t=k+1; if t>=0&&t<36864&&k/192==t/192 {n=t-192; if n<=0||n>=36864 {n=-1;}}} else if dr==6 {let t=k-1; if t>=0&&t<36864&&k/192==t/192 {n=t+192; if n<=0||n>=36864 {n=-1;}}} else if dr==7 {let t=k+1; if t>=0&&t<36864&&k/192==t/192 {n=t+192; if n<=0||n>=36864 {n=-1;}}} if n!=-1 {(*ok)[c]=u32(n); c++;} } return c; }
fn md_gen(tk: u32) { var i=0; var n=rnd(0,192); let n2=n; rnd(0,192); var f=0; var c=mdc[tk]; while i<192&&f<3000 { f++; if rnd(0,100)<10 {i--;} else {i++;} n+=select(rnd(-2,3), rnd(-3,2), n2>96); if i>=0&&i<192&&n>=0&&n<192 { let k=u32(n*192+i); if k>0u&&c<2048u { md[c*cfg.cs+tk]=k; c++; } } } mdc[tk]=c; }
fn dil(tk: u32, src: u32, dst: u32) { var pr=array<u32,6>(0u,0u,0u,0u,0u,0u); for(var y=0u; y<192u; y++) { let b=y*6u; var cr=array<u32,6>(bb[idx(src,b,tk)],bb[idx(src,b+1u,tk)],bb[idx(src,b+2u,tk)],bb[idx(src,b+3u,tk)],bb[idx(src,b+4u,tk)],bb[idx(src,b+5u,tk)]); var nr=array<u32,6>(0u,0u,0u,0u,0u,0u); if y<191u { let nb=(y+1u)*6u; nr=array<u32,6>(bb[idx(src,nb,tk)],bb[idx(src,nb+1u,tk)],bb[idx(src,nb+2u,tk)],bb[idx(src,nb+3u,tk)],bb[idx(src,nb+4u,tk)],bb[idx(src,nb+5u,tk)]); } let m0=pr[0]|cr[0]|nr[0]; let m1=pr[1]|cr[1]|nr[1]; let m2=pr[2]|cr[2]|nr[2]; let m3=pr[3]|cr[3]|nr[3]; let m4=pr[4]|cr[4]|nr[4]; let m5=pr[5]|cr[5]|nr[5]; bb[idx(dst,b,tk)]=m0|(m0<<1u)|(m0>>1u)|(m1<<31u); bb[idx(dst,b+1u,tk)]=m1|(m1<<1u)|(m1>>1u)|(m0>>31u)|(m2<<31u); bb[idx(dst,b+2u,tk)]=m2|(m2<<1u)|(m2>>1u)|(m1>>31u)|(m3<<31u); bb[idx(dst,b+3u,tk)]=m3|(m3<<1u)|(m3>>1u)|(m2>>31u)|(m4<<31u); bb[idx(dst,b+4u,tk)]=m4|(m4<<1u)|(m4>>1u)|(m3>>31u)|(m5<<31u); bb[idx(dst,b+5u,tk)]=m5|(m5<<1u)|(m5>>1u)|(m4>>31u); pr=cr; } }
fn c_mask(tk: u32, w: u32, ct: i32) -> u32 { if ct==0 {return 0xFFFFFFFFu;} let fs=bb[idx(1u,w,tk)]|bb[idx(6u,w,tk)]; let bp=bb[idx(16u,w,tk)]|bb[idx(17u,w,tk)]; if ct==1 {return fs&~bp;} if ct==2 {return fs|bb[idx(7u,w,tk)];} return ~(bb[idx(13u,w,tk)]|bb[idx(14u,w,tk)]|bb[idx(15u,w,tk)]|bb[idx(10u,w,tk)]|bb[idx(11u,w,tk)]|(bb[idx(12u,w,tk)]&~bp)); }
fn ol(tk: u32, src: u32, tg: u32, w: i32, lv: i32, mx: i32, ct: i32) { for(var i=0u; i<1152u; i++) { bb[idx(18u,i,tk)]=bb[idx(src,i,tk)]; } if lv>=100&&mx<=0 { for(var x=1151i; x>=0i; x--) { var m=bb[idx(18u,u32(x),tk)]; if x==0i {m&=~1u;} if m==0u {continue;} for(var b=31; b>=0; b--) { if (m&(1u<<u32(b)))!=0u { let k=u32(x)*32u+u32(b); let mx_x=min(191,i32(k%192u)+w); let mi_x=max(0,i32(k%192u)-w); let mx_y=min(191,i32(k/192u)+w); let mi_y=max(0,i32(k/192u)-w); var vp=(mx_x-mi_x+1)*(mx_y-mi_y+1); for(var j=0; j<vp; j++) { rnd(0,100); } } } } var c=18u; var n=19u; bb[idx(18u,0u,tk)]&=~1u; for(var s=0; s<w; s++) { dil(tk,c,n); let t=c; c=n; n=t; } for(var i=0u; i<1152u; i++) { set_m(tk,i,(bb[idx(c,i,tk)]&~bb[idx(src,i,tk)])&c_mask(tk,i,ct),tg); } } else { let lim=u32((w*2+1)*(w*2+1)); var cm=mx; for(var x=1151; x>=0; x--) { var m=bb[idx(18u,u32(x),tk)]; if x==0 {m&=~1u;} if m==0u {continue;} for(var b=31; b>=0; b--) { if (m&(1u<<u32(b)))!=0u { let k=u32(x)*32u+u32(b); let cx=i32(k%192u); let cy=i32(k/192u); for(var i=0u; i<lim; i++) { let d=b50[i]; let nx=cx+d.x; let ny=cy+d.y; if nx>=0&&nx<192&&ny>=0&&ny<192 { if rnd(0,100)>lv {continue;} let nk=u32(ny)*192u+u32(nx); let nw=nk/32u; let nb=1u<<(nk%32u); if (c_mask(tk,nw,ct)&nb)!=0u { set_m(tk,nw,nb,tg); if mx>0 { cm--; if cm==0 {break;} } } } } } } } } } }
fn opt(tk: u32, df: u32, mi: i32, ma: i32, mx: i32, ct: i32) { for(var it=0; it<mx; it++) { dil(tk,df,18u); for(var i=0u; i<1152u; i++) { let m=bb[idx(18u,i,tk)]&c_mask(tk,i,ct); var fm=0u; if m!=0u { let y=i/6u; let xw=i%6u; let c=bb[idx(df,i,tk)]; var cl=c>>1u; if xw<5u {cl|=bb[idx(df,i+1u,tk)]<<31u;} var cr=c<<1u; if xw>0u {cr|=bb[idx(df,i-1u,tk)]>>31u;} var u=0u; var ul=0u; var ur=0u; if y>0u { let ui=i-6u; u=bb[idx(df,ui,tk)]&select(0xFFFFFFFFu,0xFFFFFFFEu,ui==0u); ul=u>>1u; if xw<5u {ul|=bb[idx(df,ui+1u,tk)]<<31u;} ur=u<<1u; if xw>0u {ur|=bb[idx(df,ui-1u,tk)]>>31u;} } var d=0u; var dl=0u; var dr=0u; if y<191u { let di=i+6u; d=bb[idx(df,di,tk)]; dl=d>>1u; if xw<5u {dl|=bb[idx(df,di+1u,tk)]<<31u;} dr=d<<1u; if xw>0u {dr|=bb[idx(df,di-1u,tk)]>>31u;} } for(var b=0u; b<32u; b++) { let bit=1u<<b; if (m&bit)!=0u { var cn=0; if (cl&bit)!=0u {cn++;} if (cr&bit)!=0u {cn++;} if (u&bit)!=0u {cn++;} if (ul&bit)!=0u {cn++;} if (ur&bit)!=0u {cn++;} if (d&bit)!=0u {cn++;} if (dl&bit)!=0u {cn++;} if (dr&bit)!=0u {cn++;} if cn>=mi&&cn<=ma {fm|=bit;} } } } bb[idx(19u,i,tk)]=fm; } for(var i=0u; i<1152u; i++) { set_m(tk,i,bb[idx(19u,i,tk)],df); } } }
fn r_exp(tk: u32, df: u32, rc: i32, ec: i32, elv: i32, olv: i32, oc: i32, ct: i32, ect: i32) { let r=max(1,rc); for(var k=0; k<r; k++) { let x=u32(rnd(0,192)); let i=u32(rnd(0,192))*6u+x/32u; let b=1u<<(x%32u); if (c_mask(tk,i,ct)&b)!=0u {set_m(tk,i,b,df);} } var fl=true; for(var it=0; it<ec; it++) { for(var a=0u; a<36864u; a++) { let k=select(36863u-a,a,fl); let w=k/32u; let b=k%32u; if (bb[idx(df,w,tk)]&(1u<<b))!=0u&&rnd(0,100)<=elv { var nk=array<u32,8>(0u,0u,0u,0u,0u,0u,0u,0u); let nc=nb(i32(k),&nk); for(var d=0; d<nc; d++) { let nw=nk[d]/32u; let nb=1u<<(nk[d]%32u); if (c_mask(tk,nw,ect)&nb)!=0u {set_m(tk,nw,nb,df);} } } } fl=!fl; } if olv>0 {opt(tk,df,olv,oc,1,ect);} }
