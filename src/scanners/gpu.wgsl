fn rnd(mn: i32, mx: i32) -> i32 { var l=mn; var h=mx; if l>h {let t=l; l=h; h=t;} let du = u32(h)-u32(l); if du<=1u {return l;} wix++; if wix>=56 {wix=1;} wixp++; if wixp>=56 {wixp=1;} var n = wsa[wix]-wsa[wixp]; if n<0 {n+=2147483647;} wsa[wix]=n; let al=u32(n)&0xFFFFu; let ah=u32(n)>>16u; let bl=du&0xFFFFu; let bh=du>>16u; let p0=al*bl; let cr=ah*bl+al*bh; var rl=p0+((cr&0xFFFFu)<<16u); var cc=0u; if rl<p0 {cc=1u;} let hi = ah*bh+(cr>>16u)+(u32(cr<ah*bl)<<16u)+cc; let sh=(hi<<1u)|(rl>>31u); var sl=rl+sh; var c=u32(sl<rl); let o=sl; sl++; if sl<o {c++;} return i32(u32(l) + (((hi+c)<<1u)|(sl>>31u))); }
