struct Cfg { b: u32, min: u32, max: u32, p: u32 }
@group(0) @binding(0) var<uniform> cfg: Cfg; @group(0) @binding(1) var<storage, read_write> ba: array<u32>; @group(0) @binding(2) var<storage, read> bb: array<u32>; @group(0) @binding(3) var<storage, read_write> out: array<u32>;
@compute @workgroup_size(64) fn o(@builtin(global_invocation_id) id: vec3<u32>) { let t=id.x; if t>=cfg.b {return;} let o=t*1152u; var p=array<u32,6>(0u,0u,0u,0u,0u,0u); for(var y=0u;y<192u;y++){ let b=o+y*6u; var cr=array<u32,6>(ba[b], ba[b+1u], ba[b+2u], ba[b+3u], ba[b+4u], ba[b+5u]); var nr=array<u32,6>(0u,0u,0u,0u,0u,0u); if y<191u {let nb=o+(y+1u)*6u; nr=array<u32,6>(ba[nb], ba[nb+1u], ba[nb+2u], ba[nb+3u], ba[nb+4u], ba[nb+5u]);} for(var xw=0u;xw<6u;xw++){ let w=b+xw; let m=bb[w]; var fm=0u; if m!=0u { let c=cr[xw]; var cl=c>>1u; if xw<5u {cl|=(cr[xw+1u]<<31u);} var cr_b=c<<1u; if xw>0u {cr_b|=(cr[xw-1u]>>31u);} var u=p[xw]; if y==1u&&xw==0u {u&=0xFFFFFFFEu;} var ul=u>>1u; if xw<5u {ul|=(p[xw+1u]<<31u);} var ur=u<<1u; if xw>0u {ur|=(p[xw-1u]>>31u);} var d=nr[xw]; var dl=d>>1u; if xw<5u {dl|=(nr[xw+1u]<<31u);} var dr=d<<1u; if xw>0u {dr|=(nr[xw-1u]>>31u);} for(var bit=0u;bit<32u;bit++){ let bm=1u<<bit; if (m&bm)!=0u { var ct=0u; if(cl&bm)!=0u{ct++;} if(cr_b&bm)!=0u{ct++;} if(u&bm)!=0u{ct++;} if(ul&bm)!=0u{ct++;} if(ur&bm)!=0u{ct++;} if(d&bm)!=0u{ct++;} if(dl&bm)!=0u{ct++;} if(dr&bm)!=0u{ct++;} if ct>=cfg.min&&ct<=cfg.max {fm|=bm;} } } } out[w]=fm; } p=cr; } }
@compute @workgroup_size(64) fn a(@builtin(global_invocation_id) id: vec3<u32>) { let t=id.x; if t>=cfg.b {return;} let o=t*1152u; for(var i=0u;i<1152u;i++){ ba[o+i]|=out[o+i]; } }
@compute @workgroup_size(64) fn c(@builtin(global_invocation_id) id: vec3<u32>) { let t=id.x; if t>=cfg.b {return;} let o=t*1152u; var c=0u; for(var i=0u;i<1152u;i++){ c+=countOneBits(ba[o+i]); } out[t]=c; }